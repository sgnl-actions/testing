{
  "name": "@sgnl-actions/testing",
  "version": "1.1.0",
  "description": "Declarative scenario-based testing framework for SGNL actions (HTTP and LDAP)",
  "type": "module",
  "main": "src/index.mjs",
  "bin": {
    "sgnl-test-init": "./src/cli/init.mjs"
  },
  "exports": {
    ".": "./src/index.mjs",
    "./parse-fixture": "./src/parse-fixture.mjs",
    "./parse-scenarios": "./src/parse-scenarios.mjs",
    "./setup-nock": "./src/setup-nock.mjs",
    "./setup-ldap": "./src/setup-ldap.mjs",
    "./ldap-scenarios": "./src/ldap-scenarios.mjs",
    "./assertions": "./src/assertions.mjs"
  },
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "postinstall": "echo '\\n  Run npx sgnl-test-init to scaffold scenario tests.\\n'"
  },
  "keywords": [
    "sgnl",
    "testing",
    "actions",
    "scenarios",
    "nock",
    "ldap"
  ],
  "author": "SGNL Engineering",
  "license": "MIT",
  "dependencies": {
    "js-yaml": "^4.1.0",
    "ldapts": "^7.3.0",
    "nock": "^14.0.0",
    "yaml": "^2.8.2"
  },
  "peerDependencies": {
    "jest": ">=29.0.0"
  },
  "devDependencies": {
    "jest": "^30.0.5"
  }
}
